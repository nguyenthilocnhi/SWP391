  "components": {
    "schemas": {
      "ChangePasswordDto": {
        "required": [
          "currentPassword",
          "newPassword"
        ],
        "type": "object",
        "properties": {
          "currentPassword": {
            "maxLength": 255,
            "minLength": 8,
            "type": "string"
          },
          "newPassword": {
            "maxLength": 255,
            "minLength": 8,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateWorkSlotDto": {
        "required": [
          "date",
          "slot",
          "userId"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "slot": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "required": [
          "email",
          "fullName",
          "gender",
          "password",
          "phone",
          "roleId"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 255,
            "minLength": 0,
            "pattern": "^[\\p{L}\\s]+$",
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "gender": {
            "maxLength": 10,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "maxLength": 255,
            "minLength": 0,
            "pattern": "^[a-zA-Z0-9._%+-]+@gmail\\.com$",
            "type": "string",
            "format": "email"
          },
          "password": {
            "maxLength": 255,
            "minLength": 8,
            "type": "string",
            "format": "password"
          },
          "phone": {
            "maxLength": 20,
            "minLength": 0,
            "pattern": "^0[35789]\\d{8}$",
            "type": "string"
          },
          "address": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "roleId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UpdateConsultantProfileDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "address": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "specialization": {
            "type": "string",
            "nullable": true
          },
          "experienceYears": {
            "maximum": 100,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "consultantLicense": {
            "type": "string",
            "nullable": true
          },
          "consultantDescription": {
            "type": "string",
            "nullable": true
          },
          "room": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Nhập chuỗi token theo định dạng: Bearer {token}",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
